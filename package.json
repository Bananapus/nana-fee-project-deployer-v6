    "@bananapus/721-hook-v6": "^0.0.54",
    "@bananapus/address-registry-v6": "^0.0.26",
    "@bananapus/buyback-hook-v6": "^0.0.49",
    "@croptop/core-v6": "^0.0.52",
    "@sphinx-labs/plugins": "0.33.3",
