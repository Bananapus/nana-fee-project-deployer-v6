{
  "name": "@bananapus/fee-project-deployer-v6",
  "version": "0.0.39",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bananapus/nana-fee-project-deployer-v6.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "foundry.toml",
    "references/",
    "remappings.txt",
    "script/"
  ],
  "scripts": {
    "test": "forge test",
    "coverage": "forge coverage --match-path \"./src/*.sol\" --report lcov --report summary",
    "deploy:mainnets": "source ./.env && export START_TIME=$(date +%s) && npx sphinx propose ./script/Deploy.s.sol --networks mainnets",
    "deploy:testnets": "source ./.env && export START_TIME=$(date +%s) && npx sphinx propose ./script/Deploy.s.sol --networks testnets"
  },
  "dependencies": {
    "@bananapus/core-v6": "^0.0.86",
    "@bananapus/ownable-v6": "^0.0.39",
    "@bananapus/permission-ids-v6": "^0.0.31",
    "@bananapus/router-terminal-v6": "^0.0.66",
    "@bananapus/suckers-v6": "^0.0.73",
    "@rev-net/core-v6": "^0.0.91"
  },
  "devDependencies": {
    "@bananapus/721-hook-v6": "^0.0.73",
    "@bananapus/address-registry-v6": "^0.0.35",
    "@bananapus/buyback-hook-v6": "^0.0.71",
    "@croptop/core-v6": "^0.0.67",
    "@sphinx-labs/plugins": "0.33.3",
    "@uniswap/permit2": "github:Uniswap/permit2#cc56ad0f3439c502c246fc5cfcc3db92bb8b7219",
    "@uniswap/v4-core": "1.0.2"
  }
}
