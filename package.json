    "url": "git+https://github.com/Bananapus/nana-fee-project-deployer-v6"
  },
  "engines": {
    "node": "25.9.0"
  },
  "files": [
    "ADMINISTRATION.md",
    "ARCHITECTURE.md",
    "AUDIT_INSTRUCTIONS.md",
    "README.md",
    "RISKS.md",
    "SKILLS.md",
    "STYLE_GUIDE.md",
    "USER_JOURNEYS.md",
    "foundry.toml",
    "references/",
    "remappings.txt",
    "script/Deploy.s.sol",
    "sphinx.lock"
  ],
  "scripts": {
    "test": "forge test",
    "coverage": "forge coverage --match-path \"./src/*.sol\" --report lcov --report summary",
    "deploy:mainnets": "source ./.env && export START_TIME=$(date +%s) && npx sphinx propose ./script/Deploy.s.sol --networks mainnets",
    "deploy:testnets": "source ./.env && export START_TIME=$(date +%s) && npx sphinx propose ./script/Deploy.s.sol --networks testnets"
  },
  "dependencies": {
    "@bananapus/core-v6": "^0.0.57",
